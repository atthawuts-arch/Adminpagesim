# แอดมินซิม — server env vars
#
# Copy to .env (gitignored) for local dev, OR set these in your Railway
# project Variables tab.

# Listen port (Railway sets this automatically — leave empty there)
PORT=3000

# Typhoon API key — required for Normal/Hardcore modes
# Get one at https://opentyphoon.ai
TYPHOON_API_KEY=

# Override defaults if you need to test against a different OpenAI-compatible
# endpoint (e.g. local Ollama for dev, OpenAI proper, Together.ai)
TYPHOON_API_BASE=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2.5-30b-a3b-instruct

# CORS — restrict to your deployed origin in production. Default '*' is fine for testing.
# ALLOW_ORIGINS=https://your-app.up.railway.app,https://your-domain.com
